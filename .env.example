# Environment Variables Template
# Copy this file to .env.local and fill in your values

# Gemini API Key (for AI features)
GEMINI_API_KEY=your-gemini-api-key-here

# Supabase Configuration (Self-hosted via Docker)
NEXT_PUBLIC_SUPABASE_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-from-supabase-project-env
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-from-supabase-project-env

# SMS Provider Configuration (İletiMerkezi)
# DEMO MODE: Boş bırakırsanız SMS gönderilmez, sadece loglama yapılır
ILETIMERKEZI_USERCODE=
ILETIMERKEZI_PASSWORD=
ILETIMERKEZI_HEADER=

# Cloudflare Turnstile (Bot Protection)
# https://dash.cloudflare.com/ üzerinden alabilirsiniz (ücretsiz)
NEXT_PUBLIC_CLOUDFLARE_TURNSTILE_SITE_KEY=
CLOUDFLARE_TURNSTILE_SECRET_KEY=

# OTP Demo Mode (Test için - Production'da silin!)
# true ise: Her zaman "111111" kodu kabul edilir, SMS gönderilmez
OTP_DEMO_MODE=true

# Site URL (canonical, OG tags, SEO için)
NEXT_PUBLIC_SITE_URL=https://kuaforara.com.tr

# Sentry — Error tracking (production'da zorunlu)
# https://sentry.io/ üzerinden ücretsiz proje açıp DSN alın
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# Resend — Transactional email (randevu onay/iptal e-postaları)
# https://resend.com/ üzerinden API key alın
RESEND_API_KEY=
RESEND_FROM_EMAIL=Güzellik Randevu <noreply@kuaforara.com.tr>

# Upstash Redis — Rate limit (multi-instance prod için)
# Boşsa in-memory rate limit kullanılır (single-instance dev için yeterli)
# https://upstash.com/ üzerinden ücretsiz Redis instance alın
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=


# PayTR iFrame API (Sürüm 1.1.0 — şu an aktif ödeme sağlayıcısı, sadece abonelik için)
# Admin Panel > Ayarlar > Ödeme Sağlayıcıları'ndan DB'ye girilir (öncelikli kaynak).
# Bu env'ler DB boşsa fallback olarak kullanılabilir (lib/payment/paytr.ts şu an DB öncelikli okur).
PAYTR_MERCHANT_ID=
PAYTR_MERCHANT_KEY=
PAYTR_MERCHANT_SALT=
PAYTR_TEST_MODE=1
PAYTR_CALLBACK_URL=https://kuaforara.com.tr/api/paytr/callback
